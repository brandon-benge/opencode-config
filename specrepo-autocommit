#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage:
  specrepo-autocommit "<four-line summary>"

Runs autocommit only when the current git branch is not main. The summary must
contain exactly four non-empty lines.
USAGE
}

if [ "$#" -eq 0 ]; then
  usage
  exit 64
fi

summary="$*"
summary_line_count="$(printf '%s\n' "$summary" | sed '/^[[:space:]]*$/d' | wc -l | tr -d '[:space:]')"

if [ "$summary_line_count" != "4" ]; then
  echo "Autocommit blocked: expected a 4-line summary, got ${summary_line_count} non-empty line(s)." >&2
  exit 64
fi

branch="$(git symbolic-ref --quiet --short HEAD || true)"

if [ -z "$branch" ]; then
  branch="$(git rev-parse --short HEAD 2>/dev/null || true)"
fi

if [ -z "$branch" ]; then
  echo "Autocommit blocked: could not determine the current git branch." >&2
  exit 1
fi

if [ "$branch" = "main" ]; then
  echo "Autocommit blocked: current branch is main."
  exit 0
fi

ensure_autocommit_installed() {
  if command -v autocommit &>/dev/null; then
    return 0
  fi
  echo "autocommit CLI not found. Installing via pip3 --user..."
  pip3 install --user "git+https://github.com/brandon-benge/langchain_autocommit.git"
  user_base="$(python3 -m site --user-base)"
  export PATH="$user_base/bin:$PATH"
  if ! command -v autocommit &>/dev/null; then
    echo "Error: autocommit installed but not found on PATH at $user_base/bin." >&2
    exit 1
  fi
  echo "autocommit installed successfully."
}

if [ -n "${OPENCODE_API_KEY:-}" ]; then
  echo "OPENCODE_API_KEY is set; running opencode autocommit on branch ${branch}."
  exec opencode -c "$summary"
fi

ensure_autocommit_installed

echo "OPENCODE_API_KEY is not set; running autocommit on branch ${branch}."
exec autocommit -c "$summary"
