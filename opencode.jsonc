{
  "$schema": "https://opencode.ai/config.json",

  "agent": {
    "plan": {
      "temperature": 0.1,
      "steps": 3,
      "tools": {
        "write": false,
        "edit": false
      }
    },

    "build": {
      "temperature": 0.1,
      "steps": 10
    },

    "specrepo-bootstrapper": {
      "description": "Create a complete repo-specific SpecRepo structure and root AGENTS.md from reusable templates.",
      "prompt": "{file:./prompts/specrepo-bootstrapper.txt}",
      "mode": "primary",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "nl *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git grep*": "allow",
          "git ls-files*": "allow",
          "git rev-parse*": "allow",
          "git branch --show-current": "allow",
          "git branch --list*": "allow",
          "rg *": "allow",
          "sed -n *": "allow",
          "wc *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },

    "request-author": {
      "description": "Create or refine SpecRepo feature requests without proposing architecture or editing implementation code.",
      "prompt": "{file:./prompts/request-author.txt}",
      "mode": "primary",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "nl *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git grep*": "allow",
          "git ls-files*": "allow",
          "git rev-parse*": "allow",
          "git branch --show-current": "allow",
          "git branch --list*": "allow",
          "git switch -c request/*": "ask",
          "rg *": "allow",
          "sed -n *": "allow",
          "wc *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },

    "spec-reviewer": {
      "description": "Create architecture proposals from SpecRepo requests without implementing code.",
      "prompt": "{file:./prompts/spec-reviewer.txt}",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "nl *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git grep*": "allow",
          "git ls-files*": "allow",
          "git rev-parse*": "allow",
          "git branch --show-current": "allow",
          "git branch --list*": "allow",
          "rg *": "allow",
          "sed -n *": "allow",
          "wc *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },

    "architecture-approver": {
      "description": "Review architecture proposals and create approval records automatically.",
      "prompt": "{file:./prompts/architecture-approver.txt}",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "nl *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git grep*": "allow",
          "git ls-files*": "allow",
          "git rev-parse*": "allow",
          "git branch --show-current": "allow",
          "git branch --list*": "allow",
          "rg *": "allow",
          "sed -n *": "allow",
          "wc *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },

    "implementation-reviewer": {
      "description": "Review approved architecture and create the pre-implementation review gate.",
      "prompt": "{file:./prompts/implementation-reviewer.txt}",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "nl *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git grep*": "allow",
          "git ls-files*": "allow",
          "git rev-parse*": "allow",
          "git branch --show-current": "allow",
          "git branch --list*": "allow",
          "rg *": "allow",
          "sed -n *": "allow",
          "wc *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    },

    "spec-coder": {
      "description": "Implement approved SpecRepo changes within the approved scope.",
      "prompt": "{file:./prompts/spec-coder.txt}",
      "mode": "primary",
      "temperature": 0.2,
      "permission": {
        "read": "allow",
        "edit": "ask",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "nl *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git grep*": "allow",
          "git ls-files*": "allow",
          "git rev-parse*": "allow",
          "git branch --show-current": "allow",
          "git branch --list*": "allow",
          "$HOME/.config/opencode/specrepo-autocommit *": "ask",
          "rg *": "allow",
          "sed -n *": "allow",
          "wc *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "task": "ask"
      }
    },

    "test-reviewer": {
      "description": "Review tests and verification evidence for approved SpecRepo changes.",
      "prompt": "{file:./prompts/test-reviewer.txt}",
      "mode": "subagent",
      "temperature": 0.1,
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "bash": {
          "*": "ask",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "cat *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "nl *": "allow",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git grep*": "allow",
          "git ls-files*": "allow",
          "git rev-parse*": "allow",
          "git branch --show-current": "allow",
          "git branch --list*": "allow",
          "rg *": "allow",
          "sed -n *": "allow",
          "wc *": "allow"
        },
        "webfetch": "deny",
        "websearch": "deny",
        "task": "deny"
      }
    }
  },

  "watcher": {
    "ignore": [
      ".git/**",
      "dist/**",
      "build/**",
      ".cache/**",
      "tmp/**",
      "temp/**"
    ]
  }
}
