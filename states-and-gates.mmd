graph TD
    classDef state fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef terminal fill:#fce4ec,stroke:#c62828,stroke-width:2px
    classDef skill fill:#f3e5f5,stroke:#7b1fa2,stroke-width:1px,stroke-dasharray:5 5
    classDef decision fill:#fff8e1,stroke:#f9a825,stroke-width:2px

    Start((Start)):::terminal
    Requested[Requested]:::state
    ArchitectureProposed[Architecture Proposed]:::state
    Approved[Approved]:::state
    Rejected[Revise / Reject / Not Pursued]:::terminal
    ImplementationReviewed[Implementation Reviewed]:::state
    Implementing[Implementing]:::state
    Verified[Verified]:::state
    TestReviewed[Test Reviewed]:::state
    Closed((Closed)):::terminal

    RequestSkill["specrepo-request"]:::skill
    ProposalSkill["specrepo-proposal"]:::skill
    ApprovalSkill["specrepo-approval"]:::skill
    ImplReviewSkill["specrepo-implementation-review"]:::skill
    VerifySkill["specrepo-verification"]:::skill
    AutoCommitSkill["specrepo-autocommit"]:::skill

    Start -->|"@request-author"| RequestSkill
    RequestSkill -->|"create request"| Requested
    Requested -->|"@spec-reviewer"| ProposalSkill
    ProposalSkill -->|"create proposal"| ArchitectureProposed
    ArchitectureProposed -->|"@architecture-approver"| ApprovalSkill
    ApprovalSkill -->|"approve and create record"| Approved
    ApprovalSkill -->|"revise / reject"| Rejected
    Approved -->|"human satisfied; call @spec-coder"| ImplReviewSkill
    ImplReviewSkill -->|"proceed"| ImplementationReviewed
    ImplReviewSkill -->|"stop for revised architecture"| Rejected
    ImplementationReviewed -->|"@spec-coder implements approved scope"| Implementing
    Implementing -->|"run verification"| VerifySkill
    VerifySkill -->|"verification passed"| Verified
    VerifySkill -->|"cannot verify"| Rejected
    Verified -->|"@test-reviewer reviews evidence"| TestReviewed
    TestReviewed -->|"pass"| AutoCommitSkill
    TestReviewed -->|"needs more tests"| Implementing
    TestReviewed -->|"blocked"| Rejected
    AutoCommitSkill -->|"autocommit hook"| Closed
    Closed --> Start
