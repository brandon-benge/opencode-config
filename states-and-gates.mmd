graph TD
    classDef state fill:#e3f2fd,stroke:#1565c0,stroke-width:2px
    classDef terminal fill:#fce4ec,stroke:#c62828,stroke-width:2px
    classDef note fill:#fff8e1,stroke:#f9a825,stroke-width:1px,stroke-dasharray:5 5

    Start((Start)):::terminal
    Requested[Requested]:::state
    ArchitectureProposed[Architecture Proposed]:::state
    Approved[Approved]:::state
    Rejected[Rejected]:::state
    ImplementationReviewed[Implementation Reviewed]:::state
    Implementing[Implementing]:::state
    Verified[Verified]:::state
    Closed((Closed)):::terminal

    Start -->|"@request-author creates request"| Requested
    Requested -->|"@spec-reviewer creates proposal"| ArchitectureProposed
    ArchitectureProposed -->|"@architecture-approver auto-approves"| Approved
    ArchitectureProposed -->|Rejected or not pursued| Rejected
    Approved -->|"@implementation-reviewer confirms"| ImplementationReviewed
    ImplementationReviewed -->|"@spec-coder codes"| Implementing
    Implementing -->|Tests pass| Verified
    Verified -->|Autocommit / merge| Closed
    Rejected --> Start
    Closed --> Start

    Note1["Auto-chain from @request-author"]:::note
    Note2["No human approval prompt needed"]:::note
    Note3["@test-reviewer must pass"]:::note

    ArchitectureProposed -.- Note1
    Approved -.- Note2
    Verified -.- Note3
